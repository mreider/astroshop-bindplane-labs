# Copy to .env and fill in values for local deployment
# These are also configured as GitHub Secrets for CI/CD

# BindPlane
BINDPLANE_API_KEY=bp_XXXXX
BINDPLANE_REMOTE_URL=https://app.bindplane.com
BINDPLANE_SECRET_KEY=XXXXX

# Dynatrace
DT_ENDPOINT=https://YOUR_ENV.dev.dynatracelabs.com/api/v2/otlp
DT_API_TOKEN=dt0s16.XXXXX
DT_ENVIRONMENT=https://YOUR_ENV.dev.apps.dynatracelabs.com

# GCP / GKE
GCP_PROJECT=dynatrace-dev-on-demand
GKE_CLUSTER=astroshop-bp
GKE_REGION=us-central1
